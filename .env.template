# Copy this file to .env.local and fill in the values for your machine.
# .env.local is listed in .gitignore and will NOT be committed.

# Full path to the Python executable in your BlueSky-Gym conda/venv environment.
# Examples:
#   Windows conda : BSG_PYTHON=D:\Anaconda3\envs\bsg\python.exe
#   Linux/macOS   : BSG_PYTHON=/home/user/miniconda3/envs/bsg/bin/python
# Leave unset (or omit this file) to fall back to the `python` on your PATH.
BSG_PYTHON=
